# Aeonblight Linux server environment.
# Copy this file to .env on the server and replace every CHANGE_ME value.
# Keep DATABASE_URL password URL-safe, or URL-encode it manually.

COMPOSE_PROJECT_NAME=aeonblight
IMAGE_TAG=latest
ACCOUNT_API_IMAGE=aeonblight/account-api
ECONOMY_API_IMAGE=aeonblight/economy-api
ADMIN_API_IMAGE=aeonblight/admin-api
ECONOMY_WORKER_IMAGE=aeonblight/economy-worker
MIGRATOR_IMAGE=aeonblight/db-migrate

# Domains handled by this backend server.
# play.aeonblight.com is intentionally not listed here when the client is hosted elsewhere.
API_DOMAIN=api.aeonblight.com
GAME_DOMAIN=game.aeonblight.com
CERT_NAME=aeonblight-api-game
CERTBOT_EMAIL=ops@aeonblight.com
ACME_WEBROOT=/var/www/letsencrypt

# The game server is not built by this backend repo. Use this only for HTTP/WebSocket game traffic.
# For raw TCP/UDP game traffic, expose the game server port separately instead of proxying through this nginx template.
GAME_UPSTREAM=http://127.0.0.1:7777

# Host bindings. Keep them loopback-only and expose through nginx.
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=55432
REDIS_BIND=127.0.0.1
REDIS_PORT=56379
ACCOUNT_API_BIND=127.0.0.1
ACCOUNT_API_PORT=8081
ECONOMY_API_BIND=127.0.0.1
ECONOMY_API_PORT=8082
ADMIN_API_BIND=127.0.0.1
ADMIN_API_PORT=8083

# PostgreSQL container and app connection.
POSTGRES_DB=aeonblight_game
POSTGRES_USER=aeonblight
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD_URL_SAFE
DATABASE_URL=postgres://aeonblight:CHANGE_ME_DB_PASSWORD_URL_SAFE@postgres:5432/aeonblight_game?sslmode=disable
MIGRATION_DATABASE_URL=postgres://aeonblight:CHANGE_ME_DB_PASSWORD_URL_SAFE@127.0.0.1:55432/aeonblight_game?sslmode=disable

# Runtime profile. Production/staging refuse dev stub defaults.
APP_PROFILE=production
TEST_SCOPE=contract
STUB_MODE=disabled
INTERNAL_KEY=
REQUIRED_SCHEMA_VERSION=20260715_account_launch_admission_v1

# Redis.
REDIS_ENABLED=true
REDIS_ADDR=redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_OR_EMPTY
REDIS_DB=0
SESSION_TTL_HOURS=168
ONLINE_PRESENCE_TTL_SECONDS=90

# API secrets. Generate strong random values, for example:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET
GAME_CLIENT_BASE_URL=https://CHANGE_ME_CUSTOM_LAUNCH_ENTRYPOINT
TOKEN_SYMBOL=AEB
SUPPORT_WALLETS=phantom,solflare,backpack,okx
ADMIN_TOKEN=CHANGE_ME_RANDOM_ADMIN_BEARER_TOKEN
SUPER_ADMIN_OPS_KEY=CHANGE_ME_RANDOM_SUPER_ADMIN_KEY

# Production worker service identity.
# Register the matching public key through POST /api/admin/service-identities
# with capability economy.worker before expecting worker calls to succeed.
WORKER_SERVICE_ID=aeonblight-economy-worker-01
WORKER_SERVICE_PRIVATE_KEY=CHANGE_ME_64_BYTE_ED25519_PRIVATE_KEY_BASE58
SERVICE_AUTH_MAX_SKEW_SECONDS=120
WORKER_INTERVAL_SECONDS=15

# Economy limits.
AUTO_WITHDRAW_SINGLE_MAX=5000
USER_DAILY_WITHDRAW_MAX=20000
GLOBAL_HOURLY_WITHDRAW_MAX=30000
GLOBAL_DAILY_WITHDRAW_MAX=150000

# Solana production chain settings.
SOLANA_RPC_ENABLED=true
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=solana-mainnet
SOLANA_TOKEN_MINT=CHANGE_ME_AEB_MINT
SOLANA_TOKEN_DECIMALS=9
SOLANA_DEPOSIT_WALLET=CHANGE_ME_DEPOSIT_OWNER
SOLANA_PAYOUT_WALLET=CHANGE_ME_PAYOUT_OWNER
SOLANA_PAYOUT_PRIVATE_KEY=CHANGE_ME_HOT_WALLET_PRIVATE_KEY
SOLANA_PAYOUT_MODE=rpc
SOLANA_DEPOSIT_SCAN_LIMIT=50
SOLANA_PAYOUT_LOW_BALANCE_RAW=1000000000
