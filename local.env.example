# =============================================================================
# Aeonblight Game Backend — 本地 / 部署环境变量模板
#   cp local.env.example local.env
#
# 加载规则（internal/platform/config）：
#   - staging/production：不读文件，只用平台注入的环境变量
#   - 本地/开发：自动加载仓库根目录 ./local.env（已存在的环境变量优先，不被覆盖）
#   - Docker Compose：deploy/docker-compose.yml 通过 env_file 引用 ../local.env
#
# 标注：注释含 * 的为必配；含「*（条件）」的为开启对应功能时必配。
#
# 玩法数值（背包槽、交易行费率、掉落等）不在本文件，而在：
#   configs/economy/*.json
# =============================================================================

# =============================================================================
# A. Docker / PostgreSQL
# =============================================================================

# * Compose Postgres 库名
POSTGRES_DB=aeonblight_game
# * Compose Postgres 用户
POSTGRES_USER=aeonblight
# * Compose Postgres 密码
POSTGRES_PASSWORD=aeonblight_dev_password
# 宿主机映射端口（容器内仍是 5432）
POSTGRES_PORT=55432

# =============================================================================
# B. 服务基础
# =============================================================================

# 运行环境：test | development | staging | production
APP_PROFILE=development
# AI 测试完整度：unit | contract | integration | full
TEST_SCOPE=contract
# 链/NFT stub：enabled | disabled；staging/production 强制 disabled
STUB_MODE=enabled
# 仅 development 可显式允许 Redis 降级；默认必须连接真实 Redis
ALLOW_REDIS_FALLBACK=false

# * 本机直连 Postgres（go run / 集成测试）
DATABASE_URL=postgres://aeonblight:aeonblight_dev_password@127.0.0.1:55432/aeonblight_game?sslmode=disable
# 应用只读校验此版本，绝不会自动迁移
REQUIRED_SCHEMA_VERSION=20260715_account_launch_admission_v1

# =============================================================================
# B2. Redis（account-api 会话 / 在线状态）
# =============================================================================

# 是否启用 Redis；false 时仅 Postgres 持久化会话（无热缓存）
REDIS_ENABLED=true
# Redis 地址（本机 go run 默认 56379；Compose 内用 redis:6379）
REDIS_ADDR=127.0.0.1:56379
REDIS_PASSWORD=
REDIS_DB=0
# Compose 宿主机映射端口
REDIS_PORT=56379
# 登录会话 / refresh token TTL（小时）
SESSION_TTL_HOURS=168
# 在线 presence TTL（秒）；游戏服需在此间隔内心跳
ONLINE_PRESENCE_TTL_SECONDS=90

# 仅 development/test 的兼容密钥（请求头 X-Internal-Key）；staging/production 必须留空
INTERNAL_KEY=dev-internal-key
# 生产 worker 的独立 Ed25519 机器身份；由超级管理员登记对应公钥。
# development/test 可留空并使用上面的 legacy INTERNAL_KEY。
SERVICE_ID=
SERVICE_PRIVATE_KEY=
SERVICE_AUTH_MAX_SKEW_SECONDS=120
# * account-api JWT 签名密钥
JWT_SECRET=dev-jwt-secret
# 可选：配置后 POST /api/game/launch 会返回可直接跳转的 gameUrl
GAME_CLIENT_BASE_URL=
# 主页公开配置：Token 展示名和支持钱包入口顺序
TOKEN_SYMBOL=AEB
SUPPORT_WALLETS=phantom,solflare,backpack,okx
# development/test 兼容普通管理员 Bearer Token；staging/production 使用签名登录 JWT
ADMIN_TOKEN=dev-admin-token
# 管理员签名登录 JWT 有效期（分钟）；过期后前端应清理登录态并重新签名。
ADMIN_SESSION_TTL_MINUTES=30
# * 超级管理员运维密钥（请求头 X-Super-Admin-Key）；staging/production 必填。
# development/test 未配置时，ADMIN_TOKEN 暂以 Bootstrap Super Admin 兼容旧环境。
SUPER_ADMIN_OPS_KEY=

# 各服务监听地址（本机 go run 时使用；Compose 内由 compose 覆盖）
# ADDR=:8081

# economy-worker 调用的 economy-api 基址
ECONOMY_API_URL=http://127.0.0.1:8082
# * 经济玩法 JSON 目录（items / marketplace / recipes / loot 等）
ECONOMY_CONFIG_DIR=configs/economy
# worker 轮询间隔（秒）
WORKER_INTERVAL_SECONDS=15

# =============================================================================
# C. 提现限额（链下队列；单位与游戏内 token 整数一致）
# =============================================================================

# 单笔自动提现上限；超过进 MANUAL_REVIEW
AUTO_WITHDRAW_SINGLE_MAX=5000
# 单用户每日自动提现上限
USER_DAILY_WITHDRAW_MAX=20000
# 全服每小时自动提现上限
GLOBAL_HOURLY_WITHDRAW_MAX=30000
# 全服每日自动提现上限
GLOBAL_DAILY_WITHDRAW_MAX=150000

# =============================================================================
# D. Solana 链（充值扫描 / 提现上链 / 钱包扩槽收款）
#
#   STUB_MODE=enabled 时允许本地 stub；disabled 时要求完整真链配置。
#   开启真链前请填 mint、充值收款钱包，并确认 PAYOUT_MODE。
# =============================================================================

# 是否启用 Solana JSON-RPC（充值扫描、确认等）
SOLANA_RPC_ENABLED=false
# RPC 地址
SOLANA_RPC_URL=https://api.devnet.solana.com
# 网络名（写入 chain_cursors / hot_wallet_status）
SOLANA_NETWORK=solana-devnet

# *（条件）SPL Token mint；SOLANA_RPC_ENABLED=true 时必配
SOLANA_TOKEN_MINT=
# mint 小数位；入账时 raw / 10^decimals → 游戏整数余额
SOLANA_TOKEN_DECIMALS=9

# *（条件）充值收款钱包（owner）；入账扫描与交易行钱包扩槽收款地址
SOLANA_DEPOSIT_WALLET=
# 提现热钱包地址（可与 deposit 相同；用于 hot_wallet_status）
SOLANA_PAYOUT_WALLET=
# *（条件）提现热钱包私钥（base58 64-byte 或 JSON byte 数组）；SOLANA_PAYOUT_MODE=rpc 时必配
# 切勿提交真实私钥到仓库；仅放 local.env / 密钥管理
SOLANA_PAYOUT_PRIVATE_KEY=

# 提现上链模式：
#   stub   — processWithdrawals 时直接 CONFIRMED（本地默认）
#   record — 写入 solana_payouts 并标记 SUBMITTED，不强制真链签名
#   rpc    — 用 SOLANA_PAYOUT_PRIVATE_KEY 签名 SPL TransferChecked 并 sendTransaction
#            收款方 ATA 必须已存在（玩家需已持有 AEB）；缺失则该笔 FAILED，不自动建 ATA
SOLANA_PAYOUT_MODE=stub
# 单次充值扫描最多拉取的 signature 数
SOLANA_DEPOSIT_SCAN_LIMIT=50
# 热钱包 ATA raw 余额低于此值时暂停提现（0=仅在余额为 0 时暂停）
SOLANA_PAYOUT_LOW_BALANCE_RAW=0

# --- D2. Solana Mainnet（上线时改用下面，并关闭 stub）---
# SOLANA_RPC_ENABLED=true
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_NETWORK=solana-mainnet
# SOLANA_TOKEN_MINT=<mainnet AEB mint>
# SOLANA_TOKEN_DECIMALS=9
# SOLANA_DEPOSIT_WALLET=<treasury owner>
# SOLANA_PAYOUT_WALLET=<payout hot wallet>
# SOLANA_PAYOUT_PRIVATE_KEY=<hot wallet secret>
# SOLANA_PAYOUT_MODE=rpc
# SOLANA_PAYOUT_LOW_BALANCE_RAW=1000000000
# =============================================================================
# E. 玩法 JSON 配置位置（非 env，改文件即可热更需重启 economy-api）
# =============================================================================
#
# configs/economy/economy_rules.json   — bagSlots / warehouseSlots / 冷却
# configs/economy/marketplace.json     — 交易行开关、费率、日限、扩槽
# configs/economy/items.json           — 物品目录、tradable、defaultBindType
# configs/economy/recipes.json         — 合成
# configs/economy/loot_pools.json      — 掉落池
# configs/economy/dungeons.json        — 副本
# configs/economy/gathering.json       — 采集
# configs/economy/farming.json         — 种植
# configs/economy/bosses.json          — Boss
# configs/economy/equipment_affixes.json — 装备词缀
#
# DB 运营种子（migrations/aeonblight_full_schema.sql → economy_config_versions）：
#   chain.default / withdrawal.limits / game.cooldownTiers / gold.convert
